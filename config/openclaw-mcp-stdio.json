{
  "mcpServers": {
    "evc-mesh": {
      "command": "evc-mesh-mcp",
      "args": ["--transport", "stdio"],
      "env": {
        "MESH_AGENT_KEY": "${MESH_AGENT_KEY}",
        "DB_HOST": "${DB_HOST:-localhost}",
        "DB_PORT": "${DB_PORT:-5437}",
        "DB_USER": "${DB_USER:-mesh}",
        "DB_PASSWORD": "${DB_PASSWORD:-mesh}",
        "DB_NAME": "${DB_NAME:-mesh}",
        "REDIS_HOST": "${REDIS_HOST:-localhost}",
        "REDIS_PORT": "${REDIS_PORT:-6383}",
        "NATS_URL": "${NATS_URL:-nats://localhost:4223}",
        "S3_ENDPOINT": "${S3_ENDPOINT:-localhost:9002}",
        "S3_ACCESS_KEY_ID": "${S3_ACCESS_KEY_ID:-minioadmin}",
        "S3_SECRET_ACCESS_KEY": "${S3_SECRET_ACCESS_KEY:-minioadmin}",
        "S3_BUCKET": "${S3_BUCKET:-mesh-artifacts}"
      }
    }
  }
}
